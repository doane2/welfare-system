{
  "name": "welfare-system",
  "version": "1.0.0",
  "description": "Welfare Management System Monorepo",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=crater-sda-welfare-web",
    "dev:backend": "cd apps/backend && npm run dev",
    "build": "npm run build --workspace=crater-sda-welfare-web",
    "build:frontend": "npm run build --workspace=crater-sda-welfare-web",
    "start:frontend": "npm run start --workspace=crater-sda-welfare-web",
    "start:backend": "npm run start --workspace=backend",
    "clean": "rmdir /s /q node_modules & rmdir /s /q apps\\frontend\\node_modules & rmdir /s /q apps\\backend\\node_modules & rmdir /s /q apps\\frontend\\.next"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^7.6.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "web-push": "^3.6.7"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=8.0.0"
  }
}
